OPENAI_API_KEY=<SECRET>

# Repository root is treated as the Obsidian vault by default.
AUTOBIO_VAULT_ROOT=/Users/duckworth/Documents/autobio

# Phase 1 defaults keep the audio pipeline inside the repo.
# You can later move these to ~/AutobioPipeline/... without changing the code.
AUTOBIO_INCOMING_DIR=/Users/duckworth/Documents/autobio/pipeline/incoming-audio
AUTOBIO_PROCESSED_DIR=/Users/duckworth/Documents/autobio/pipeline/processed-audio
AUTOBIO_FAILED_DIR=/Users/duckworth/Documents/autobio/pipeline/failed-audio
AUTOBIO_VOICE_MEMOS_RECORDINGS_DIR=/Users/duckworth/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings
AUTOBIO_VOICE_MEMOS_DB_PATH=/Users/duckworth/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings/CloudRecordings.db

AUTOBIO_TRANSCRIPTION_MODEL=gpt-4o-transcribe
AUTOBIO_POLL_INTERVAL_SECONDS=10
AUTOBIO_TRANSCRIPTION_PROMPT=Transcribe this memoir recording faithfully. Preserve the speaker's wording, uncertainty, and punctuation. Do not summarize or invent missing details.
