#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
PYTHON_BIN=${AUTOBIO_PYTHON_BIN:-"$ROOT_DIR/.venv/bin/python"}

if [ ! -x "$PYTHON_BIN" ]; then
  echo "Missing Python runtime at $PYTHON_BIN. Run uv sync first." >&2
  exit 1
fi

exec "$PYTHON_BIN" "$ROOT_DIR/src/autobio_pipeline/cli.py" "$@"
